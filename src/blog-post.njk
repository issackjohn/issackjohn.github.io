---
layout: base.njk
pagination:
  data: collections.blog
  size: 1
  alias: post
permalink: "/blog/{{ post.fileSlug }}/"
---

<article class="post-content-wrapper pt-32 pb-16">
    <header class="mb-12">
        <div class="flex items-center gap-3 mb-6">
            <a href="/blog/" class="text-xs font-mono uppercase tracking-widest text-ink/40 hover:text-signal transition-colors">← Blog</a>
        </div>
        <h1 class="text-4xl md:text-5xl font-serif font-medium text-ink leading-tight mb-4">{{ post.data.title }}</h1>
        <div class="flex items-center gap-4 text-xs font-mono text-ink/50">
            <time datetime="{{ post.data.date | isoDate }}">{{ post.data.date | dateFormat }}</time>
            {% if post.data.tags %}
                <div class="flex gap-2">
                    {% for tag in post.data.tags %}
                        <span class="px-2 py-0.5 bg-cream border border-ink/10">{{ tag }}</span>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </header>
    
    <div class="post-content">
        {{ post.templateContent | safe }}
    </div>
    
    <nav class="flex justify-between items-center pt-12 mt-12 border-t border-ink/10" aria-label="Post navigation">
        {% if pagination.href.previous %}
            <a href="{{ pagination.href.previous }}" rel="prev" class="text-sm text-ink/60 hover:text-signal transition-colors">← Previous</a>
        {% else %}
            <span></span>
        {% endif %}
        {% if pagination.href.next %}
            <a href="{{ pagination.href.next }}" rel="next" class="text-sm text-ink/60 hover:text-signal transition-colors">Next →</a>
        {% else %}
            <span></span>
        {% endif %}
    </nav>
</article>