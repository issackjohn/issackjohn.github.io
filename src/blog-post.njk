---
layout: base.njk
pagination:
  data: collections.blog
  size: 1
  alias: post
permalink: "/blog/{{ post.fileSlug }}/"
---

<article class="post-content-wrapper">
    <header class="page-header">
        <p class="section-title"><a href="/blog/" style="color: inherit; text-decoration: none;">Blog</a></p>
        <h1>{{ post.data.title }}</h1>
        <div class="post-meta" style="margin-top: 1rem;">
            <time datetime="{{ post.data.date | isoDate }}">{{ post.data.date | dateFormat }}</time>
            {% if post.data.tags %}
                <ul class="tags" aria-label="Tags">
                    {% for tag in post.data.tags %}
                        <li>{{ tag }}</li>
                    {% endfor %}
                </ul>
            {% endif %}
        </div>
    </header>
    
    <div class="post-content">
        {{ post.templateContent | safe }}
    </div>
    
    <footer>
        <nav class="post-navigation" aria-label="Post navigation">
            {% if pagination.previousPageLink %}
                <a href="{{ pagination.previousPageLink }}" rel="prev">← Previous</a>
            {% else %}
                <span></span>
            {% endif %}
            {% if pagination.nextPageLink %}
                <a href="{{ pagination.nextPageLink }}" rel="next">Next →</a>
            {% else %}
                <span></span>
            {% endif %}
        </nav>
        
        <p style="text-align: center; margin-top: 2rem;"><a href="/blog/" class="read-more">← All posts</a></p>
    </footer>
</article>