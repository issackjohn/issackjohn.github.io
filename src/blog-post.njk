---
layout: base.njk
pagination:
  data: collections.blog
  size: 1
  alias: post
permalink: "/blog/{{ post.fileSlug }}/"
---

<article>
    <header class="post-header">
        <h1>{{ post.data.title }}</h1>
        <div class="post-meta">
            <time datetime="{{ post.data.date | isoDate }}">{{ post.data.date | dateFormat }}</time>
            {% if post.data.tags %}
                <ul class="tags" aria-label="Tags">
                    {% for tag in post.data.tags %}
                        <li>{{ tag }}</li>
                    {% endfor %}
                </ul>
            {% endif %}
        </div>
    </header>
    
    <div class="post-content">
        {{ post.templateContent | safe }}
    </div>
    
    <footer class="post-footer">
        <nav class="post-navigation" aria-label="Post navigation">
            {% if pagination.previousPageLink %}
                <a href="{{ pagination.previousPageLink }}" rel="prev">← Previous Post</a>
            {% endif %}
            {% if pagination.nextPageLink %}
                <a href="{{ pagination.nextPageLink }}" rel="next">Next Post →</a>
            {% endif %}
        </nav>
        
        <p><a href="/blog/">← Back to all posts</a></p>
    </footer>
</article>