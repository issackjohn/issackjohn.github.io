---
layout: base.njk
title: "Home"
summary: "Web Performance & Simplicity"
---

<header class="hero">
    <h1>{{ site.title }}</h1>
    <p class="tagline">Web Performance & Simplicity</p>
</header>

<!-- Blog Posts Section -->
<section aria-labelledby="blog-heading">
    <h2 id="blog-heading">Latest Blog Posts</h2>
    {% if collections.blog.length > 0 %}
        <div class="blog-grid">
            {% for post in collections.blog | limit(3) %}
                <article class="blog-card">
                    <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
                    <p>{{ post.data.summary }}</p>
                    <time datetime="{{ post.data.date | isoDate }}">{{ post.data.date | dateFormat }}</time>
                    <a href="{{ post.url }}" aria-label="Read more about {{ post.data.title }}">Read more</a>
                </article>
            {% endfor %}
        </div>
        <p><a href="/blog/">View all blog posts</a></p>
    {% else %}
        <p>No blog posts yet. Check back soon!</p>
    {% endif %}
</section>

<!-- Projects Section -->
<section aria-labelledby="projects-heading">
    <h2 id="projects-heading">Featured Projects</h2>
    {% if projects.projects.length > 0 %}
        <div class="projects-grid">
            {% for project in projects.projects | limit(3) %}
                <article class="project-card">
                    <h3><a href="{{ project.url }}">{{ project.title }}</a></h3>
                    {% if project.description %}
                        <p>{{ project.description }}</p>
                    {% endif %}
                    {% if project.date %}
                        <time datetime="{{ project.date }}">{{ project.date | dateFormat }}</time>
                    {% endif %}
                </article>
            {% endfor %}
        </div>
        <p><a href="/projects/">View all projects</a></p>
    {% endif %}
</section>

<!-- Videos Section -->
<section aria-labelledby="videos-heading">
    <h2 id="videos-heading">Recommended Videos</h2>
    {% if videos.videos.length > 0 %}
        <ul class="videos-list">
            {% for video in videos.videos %}
                <li>
                    <a href="{{ video.url }}">{{ video.title }}</a>
                    {% if video.description %}
                        <span class="video-description">{{ video.description }}</span>
                    {% endif %}
                </li>
            {% endfor %}
        </ul>
    {% endif %}
</section>