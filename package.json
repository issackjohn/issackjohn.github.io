{
    "name": "issackjohn.github.io",
    "version": "1.0.0",
    "description": "",
    "main": "index.js",
    "scripts": {
        "start": "npm run dev",
        "dev": "eleventy --serve",
        "build": "npm run build:css && eleventy",
        "build:css": "npx tailwindcss -i src/assets/css/input.css -o _site/assets/css/main.css --minify",
        "dev:css": "npx tailwindcss -i src/assets/css/input.css -o _site/assets/css/main.css --watch",
        "lint": "eslint src/assets/js/**/*.js",
        "lint:fix": "eslint src/assets/js/**/*.js --fix",
        "pretty:check": "prettier --check ./",
        "pretty:fix": "prettier --write ./"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/issackjohn/issackjohn.github.io.git"
    },
    "author": "issack john",
    "license": "ISC",
    "bugs": {
        "url": "https://github.com/issackjohn/issackjohn.github.io/issues"
    },
    "homepage": "https://github.com/issackjohn/issackjohn.github.io#readme",
    "devDependencies": {
        "@11ty/eleventy": "^3.1.2",
        "eslint": "^8.57.1",
        "prettier": "^3.3.2",
        "tailwindcss": "^3.4.17"
    }
}
